<h1>Contact page</h1>

<form class="contact--form" name="contact" method="POST" action="/message-sent.html" netlify-honeypot="bot-field" netlify>
    <p class="hidden">
        <label>Don’t fill this out if you're human: <input name="bot-field"/></label>
    </p>

    <label for="full_name">Full name</label>
    <input type="text" name="full_name" id="full_name" placeholder="Your name" required/>

    <label for="email">Your email</label>
    <input type="email" id="email" name="email" placeholder="Your email" required/>

    <label for="message">Your message</label>
    <textarea id="message" rows="4" name="message" placeholder="Your message..." required
    ></textarea>

    <label for="privacy_accepted">
        <input id="privacy_accepted" type="checkbox" value="1" name="gdpr" required/>
        I have read and accepted the <a href="#">Privacy Policy</a>.</label>

    <button type="submit">Send message</button>
</form>

